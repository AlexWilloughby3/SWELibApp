# Database (used by docker-compose for both api and db containers)
PG_PASSWORD=changeme

# JWT signing secret (used by the Lean server for auth tokens)
JWT_SECRET=changeme

# Provisioner (only needed if deploying to GCE)
GCP_PROJECT=my-project-123
GCP_ZONE=us-central1-a
GCP_SERVICE_ACCOUNT_KEY=/path/to/service-account.json
SSH_KEY_PATH=~/.ssh/id_ed25519
SSH_USER=deploy
VM_NAME=productivity-tracker-vm
VM_MACHINE_TYPE=e2-small
STOP_VM_ON_SHUTDOWN=false
